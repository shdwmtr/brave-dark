  "version": "1.1",
  "name": "Dark Theme",
  "description": "A sleek dark theme for Brave browser",
  "theme": {
    "colors": {
      "frame": [30, 30, 30],
      "frame_inactive": [30, 30, 30],
      "frame_incognito": [30, 30, 30],
      "frame_incognito_inactive": [30, 30, 30],
      "toolbar": [55, 55, 55],
      "tab_text": [220, 220, 220],
